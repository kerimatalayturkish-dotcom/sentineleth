# ─── Chain & App (public, embedded in HTML) ───
# Sepolia: 11155111 | Mainnet: 1
NEXT_PUBLIC_ETH_CHAIN_ID=11155111
NEXT_PUBLIC_ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_ETH_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_CHAIN_NAME=Sepolia
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# Dev-only: a single allowed cross-origin host for Next 16 dev warnings
# (e.g. an ngrok tunnel). Leave blank in production.
NEXT_PUBLIC_DEV_ORIGIN=

# ─── Mining / $SENTI public config ───
# testnet first; switch to mainnet by env only after testnet + audit pass.
NEXT_PUBLIC_MINING_DEPLOYMENT=testnet
NEXT_PUBLIC_MINING_BACKEND_URL=http://localhost:3000

# Mainnet SentinelETH NFT source used read-only for mining eligibility/power.
NEXT_PUBLIC_NFT_SOURCE_CHAIN_ID=1
NEXT_PUBLIC_NFT_SOURCE_CHAIN_NAME=Ethereum
NEXT_PUBLIC_NFT_SOURCE_CONTRACT_ADDRESS=0x531cb7619cea5e0b5a8454a08f56e725c1db273e
NEXT_PUBLIC_NFT_SOURCE_EXPLORER_URL=https://etherscan.io
# Optional public NFT read endpoints for client-side reads. Prefer server-only
# NFT_SOURCE_RPC_URL/NFT_SOURCE_WS_URL when API keys should stay private.
NEXT_PUBLIC_NFT_SOURCE_RPC_URL=
NEXT_PUBLIC_NFT_SOURCE_WS_URL=

# Active mining chain. Testnet contracts live here during development.
NEXT_PUBLIC_MINING_CHAIN_ID=11155111
NEXT_PUBLIC_MINING_CHAIN_NAME=Sepolia
NEXT_PUBLIC_MINING_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_MINING_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_MINING_EXPLORER_URL=https://sepolia.etherscan.io

# Filled after testnet/mainnet deploys. Empty is valid before deploy.
NEXT_PUBLIC_SENTI_TOKEN_ADDRESS=
# Required before mining starts. Stores finalized trait values, layer weights,
# synergy multipliers, and rule commitments used by backend power calculation.
NEXT_PUBLIC_TRAIT_REGISTRY_ADDRESS=
NEXT_PUBLIC_PATROL_MINER_ADDRESS=
NEXT_PUBLIC_SENTI_HOOK_ADDRESS=
NEXT_PUBLIC_SENTI_LIQUIDITY_MANAGER_ADDRESS=
NEXT_PUBLIC_SENTI_V4_POOL_ID=

# External protocol/admin addresses for the active mining chain.
NEXT_PUBLIC_UNISWAP_V4_POOL_MANAGER_ADDRESS=
NEXT_PUBLIC_UNISWAP_V4_POSITION_MANAGER_ADDRESS=
NEXT_PUBLIC_MINING_ADMIN_SAFE_ADDRESS=
NEXT_PUBLIC_MINING_OPS_SAFE_ADDRESS=
NEXT_PUBLIC_MINING_BACKEND_SIGNER_ADDRESS=

# Optional deploy-script overrides for the protocol-owned LP manager bootstrap.
UNISWAP_PERMIT2_ADDRESS=
SENTI_V4_POOL_FEE=3000
SENTI_V4_POOL_TICK_SPACING=60
SENTI_V4_POOL_SENTI_IS_CURRENCY0=false
SENTI_COMPOUND_MIN_ETH=0.5
SENTI_COMPOUND_COOLDOWN=3600
SENTI_COMPOUND_MAX_ETH=2
SENTI_COMPOUND_MAX_SENTI=1000
SENTI_COMPOUND_MAX_DEADLINE_WINDOW=600

# Cloudflare Turnstile site key for /mine. Secret key stays server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── Server-only RPC (private endpoints, NOT exposed) ───
# Optional shortcut used by Hardhat if SEPOLIA_RPC_URL/MAINNET_RPC_URL are not
# set. Alchemy is an RPC provider; it cannot replace ETHERSCAN_API_KEY for
# explorer source-code verification.
ALCHEMY_API_KEY=
# Required only when running `hardhat verify` against Etherscan/Sepolia
# Etherscan. Not required for local testnet mining or contract calls.
ETHERSCAN_API_KEY=
# Hot-path RPC for relayer/MCP. Use a private Alchemy/QuickNode endpoint.
MINT_RPC_URL=
# Per-network fallbacks (optional, used if MINT_RPC_URL is unset).
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
# Mining backend dual-chain reads/writes. During testnet, NFT_SOURCE_* reads
# Ethereum mainnet SentinelETH only; MINING_* writes/reads testnet contracts.
NFT_SOURCE_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NFT_SOURCE_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MINING_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MINING_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# How far back to scan Transfer logs for /api/nft/my-holdings (default 100000).
HOLDINGS_LOOKBACK_BLOCKS=100000

# TraitRegistry deploy/load/finalize. The one-shot deploy script defaults admin
# to the deployer because finalized registries cannot be rewritten. Set
# TRAIT_REGISTRY_ALLOW_DRAFT=true only for testnet draft deployments.
TRAIT_REGISTRY_ADMIN_ADDRESS=
TRAIT_REGISTRY_ALLOW_DRAFT=
TRAIT_REGISTRY_LOADER=

# SENTI + PatrolMiner deploy. Non-local deployments require explicit admin,
# backend signer, and finalized TraitRegistry address. PatrolMiner uses fixed
# allocation constants: 599.8M mineable SENTI, 200k initial LP seed, and 400M
# phase-two reserve. Mining starts later through the /admin button by calling
# PatrolMiner.startMining(); skipped chain blocks do not consume reward rounds.
MINING_ADMIN_SAFE_ADDRESS=
MINING_BACKEND_SIGNER_ADDRESS=
MINING_TRAIT_REGISTRY_ADDRESS=
# Testnet/admin-dashboard signer for PatrolMiner.startMining(). On mainnet this
# should be replaced by Safe execution instead of a hot server key.
MINING_ADMIN_PRIVATE_KEY=
# Mainnet guard for the irreversible SENTI minter handoff to PatrolMiner.
MINING_CONFIRM_MAINNET_DEPLOY=

# ─── Server Keys (role-separated, AccessControl) ───
# DEFAULT_ADMIN_ROLE — deploys, grants/revokes roles.
# Transfer to treasury Safe after launch.
OWNER_PRIVATE_KEY=
# URI_SETTER_ROLE — watcher hot key, calls setTokenURI after each mint.
SERVER_PRIVATE_KEY=
# Funds the Irys uploader (image + metadata pinning).
# Same address as SERVER_PRIVATE_KEY is fine.
IRYS_PRIVATE_KEY=
# Treasury Safe address (provided by finance team). Receives ETH from mints.
NFT_TREASURY_WALLET=

# ─── Irys ───
# Mainnet: https://uploader.irys.xyz | Devnet: https://devnet.irys.xyz
IRYS_NETWORK=devnet
IRYS_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Database (Postgres) ───
# DATABASE_URL is used by the existing NFT merkle/watcher/retry flow.
# MINING_DATABASE_URL is required for the mining backend worker/session layer
# (heartbeats, challenge attempts, power snapshots, winner/claim idempotency),
# but not for contract deploys or the /admin startMining button.
DATABASE_URL=postgresql://user:password@host:5432/sentinel_eth
MINING_DATABASE_URL=
# Secure default for remote Postgres. Set to no-verify only if your provider
# cannot be verified yet and you accept that risk temporarily.
MINING_DATABASE_SSL_MODE=require

# ─── Mining signer / bot gate ───
# Current runtime implements local winner signing only. Managed signer
# credentials are reserved for a future Turnkey integration.
MINING_SIGNER_MODE=local
MINING_SIGNER_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
TURNKEY_PRIVATE_KEY_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Admin dashboard ───
ADMIN_USERNAME=admin
# Plaintext admin password — compared in constant time on the server
# (sha256 + timingSafeEqual). Prefer ADMIN_PASSWORD_HASH instead and keep this
# blank in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=
# HS256 signing secret for the admin session JWT. Must be >= 32 chars.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── Notifications ───
# Discord webhook for watcher alerts (mint failures, retry exhaustion).
DISCORD_WEBHOOK_URL=
