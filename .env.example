# ─── Chain & App (public, embedded in HTML) ───
# Sepolia: 11155111 | Mainnet: 1
NEXT_PUBLIC_ETH_CHAIN_ID=11155111
NEXT_PUBLIC_ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_ETH_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_CHAIN_NAME=Sepolia
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# Dev-only: a single allowed cross-origin host for Next 16 dev warnings
# (e.g. an ngrok tunnel). Leave blank in production.
NEXT_PUBLIC_DEV_ORIGIN=

# ─── Server-only RPC (private endpoints, NOT exposed) ───
# Hot-path RPC for relayer/MCP. Use a private Alchemy/QuickNode endpoint.
MINT_RPC_URL=
# Per-network fallbacks (optional, used if MINT_RPC_URL is unset).
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
# How far back to scan Transfer logs for /api/nft/my-holdings (default 100000).
HOLDINGS_LOOKBACK_BLOCKS=100000

# ─── Server Keys (role-separated, AccessControl) ───
# DEFAULT_ADMIN_ROLE — deploys, grants/revokes roles.
# Transfer to treasury Safe after launch.
OWNER_PRIVATE_KEY=
# URI_SETTER_ROLE — watcher hot key, calls setTokenURI after each mint.
SERVER_PRIVATE_KEY=
# Funds the Irys uploader (image + metadata pinning).
# Same address as SERVER_PRIVATE_KEY is fine.
IRYS_PRIVATE_KEY=
# Treasury Safe address (provided by finance team). Receives ETH from mints.
NFT_TREASURY_WALLET=

# ─── Irys ───
# Mainnet: https://uploader.irys.xyz | Devnet: https://devnet.irys.xyz
IRYS_NETWORK=devnet
IRYS_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Database (Postgres, required) ───
# Used for merkle proofs, watcher cursor, retry queue.
DATABASE_URL=postgresql://user:password@host:5432/sentinel_eth

# ─── Admin dashboard ───
ADMIN_USERNAME=admin
# Plaintext admin password — compared in constant time on the server
# (sha256 + timingSafeEqual). Use a strong, random value (>= 24 chars).
# Generate with:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSWORD=
# HS256 signing secret for the admin session JWT. Must be >= 32 chars.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── Notifications ───
# Discord webhook for watcher alerts (mint failures, retry exhaustion).
DISCORD_WEBHOOK_URL=
