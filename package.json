{
  "name": "sentinel-eth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "admin:2fa:generate": "tsx scripts/generate-admin-totp.ts",
    "generate-merkle": "tsx --env-file=.env.local scripts/generate-merkle.ts",
    "mining:minted:audit": "node mining-sentinel/scripts/audit-minted-synergies.mjs",
    "mining:registry:build": "node mining-sentinel/scripts/build-trait-rules-registry.mjs --write",
    "mining:registry:deploy:local": "pnpm --dir contracts deploy:trait-registry:local",
    "mining:registry:deploy:sepolia": "pnpm --dir contracts deploy:trait-registry:sepolia",
    "mining:registry:deploy:mainnet": "pnpm --dir contracts deploy:trait-registry:mainnet",
    "mining:core:deploy:local": "pnpm --dir contracts deploy:mining-core:local",
    "mining:core:deploy:sepolia": "pnpm --dir contracts deploy:mining-core:sepolia",
    "mining:core:deploy:mainnet": "pnpm --dir contracts deploy:mining-core:mainnet",
    "mining:nft:deploy:sepolia": "pnpm --dir contracts deploy:test-nft:sepolia",
    "mining:power:audit": "node mining-sentinel/scripts/build-trait-registry.mjs --write",
    "mining:power:audit:live": "node mining-sentinel/scripts/build-trait-registry.mjs --live --write",
    "mining:traits:verify": "node mining-sentinel/scripts/verify-trait-power.mjs",
    "mining:traits:report": "node mining-sentinel/scripts/verify-trait-power.mjs --write-report",
    "mining:db:start": "tsx --env-file=.env.local scripts/ensure-local-postgres.ts start",
    "mining:db:status": "tsx --env-file=.env.local scripts/ensure-local-postgres.ts status",
    "mining:migrate": "tsx --env-file=.env.local scripts/migrate-mining-db.ts",
    "mining:worker:once": "tsx --env-file=.env.local scripts/run-mining-worker.ts",
    "mining:worker": "tsx --env-file=.env.local scripts/run-mining-worker.ts --loop",
    "watcher": "tsx scripts/run-watcher.ts",
    "watcher:local": "tsx --env-file=.env.local scripts/run-watcher.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@irys/upload": "^0.0.15",
    "@irys/upload-ethereum": "^0.0.16",
    "@metamask/connect-evm": "^0.9.1",
    "@openzeppelin/merkle-tree": "^1.0.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-query": "^5.0.0",
    "@types/three": "^0.184.1",
    "argon2": "^0.44.0",
    "async-mutex": "^0.5.0",
    "axios": "^1.16.1",
    "bn.js": "^5.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "debug": "^4.4.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "postprocessing": "^6.39.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sharp": "^0.33.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.43.0",
    "wagmi": "^3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
